<?xml version="1.0" encoding="utf-8"?>
<resources>
    
    <!-- الثيم الرئيسي للتطبيق (النهار) -->
    <style name="Theme.NetworkCards" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- الألوان الأساسية -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorAccent">@color/accent</item>
        
        <!-- ألوان السطح والخلفية -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorBackground">@color/background</item>
        
        <!-- ألوان النص -->
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>
        <item name="colorOnBackground">@color/on_background</item>
        
        <!-- ألوان الحالة -->
        <item name="colorError">@color/error</item>
        <item name="colorErrorContainer">@color/error</item>
        <item name="colorOnError">@android:color/white</item>
        
        <!-- شريط الحالة -->
        <item name="android:statusBarColor">@color/primary_variant</item>
        <item name="android:windowLightStatusBar">false</item>
        
        <!-- شريط التنقل -->
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightNavigationBar">true</item>
        
        <!-- الخطوط -->
        <item name="fontFamily">@font/tajawal_regular</item>
        <item name="android:fontFamily">@font/tajawal_regular</item>
        
        <!-- الأشكال -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.NetworkCards.SmallComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.NetworkCards.MediumComponent</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.NetworkCards.LargeComponent</item>
        
        <!-- مكونات Material -->
        <item name="materialButtonStyle">@style/Widget.NetworkCards.Button</item>
        <item name="textInputStyle">@style/Widget.NetworkCards.TextInputLayout</item>
        <item name="materialCardViewStyle">@style/Widget.NetworkCards.CardView</item>
        <item name="chipStyle">@style/Widget.NetworkCards.Chip</item>
        
        <!-- الانتقالات -->
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:windowEnterTransition">@transition/slide_right</item>
        <item name="android:windowExitTransition">@transition/slide_left</item>
    </style>
    
    <!-- ثيم بدون شريط علوي -->
    <style name="Theme.NetworkCards.NoActionBar" parent="Theme.NetworkCards">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
    
    <!-- ثيم شاشة البداية -->
    <style name="Theme.NetworkCards.Splash" parent="Theme.NetworkCards.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
    </style>
    
    <!-- ثيم شاشة كاملة -->
    <style name="Theme.NetworkCards.FullScreen" parent="Theme.NetworkCards.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
    </style>
    
    <!-- الوضع المظلم -->
    <style name="Theme.NetworkCards.Dark" parent="Theme.Material3.Dark.NoActionBar">
        <!-- الألوان الأساسية للوضع المظلم -->
        <item name="colorPrimary">@color/dark_primary</item>
        <item name="colorPrimaryVariant">@color/dark_primary_variant</item>
        <item name="colorSecondary">@color/dark_secondary</item>
        
        <!-- ألوان السطح للوضع المظلم -->
        <item name="colorSurface">@color/dark_surface</item>
        <item name="colorBackground">@color/dark_background</item>
        <item name="colorOnSurface">@color/dark_on_surface</item>
        <item name="colorOnBackground">@color/dark_on_background</item>
        
        <!-- شريط الحالة للوضع المظلم -->
        <item name="android:statusBarColor">@color/dark_background</item>
        <item name="android:windowLightStatusBar">false</item>
        
        <!-- شريط التنقل للوضع المظلم -->
        <item name="android:navigationBarColor">@color/dark_surface</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
    
    <!-- أشكال المكونات -->
    <style name="ShapeAppearance.NetworkCards.SmallComponent" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>
    
    <style name="ShapeAppearance.NetworkCards.MediumComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>
    
    <style name="ShapeAppearance.NetworkCards.LargeComponent" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
    
    <!-- أنماط النصوص المخصصة -->
    <style name="TextAppearance.NetworkCards.Headline1" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="fontFamily">@font/tajawal_bold</item>
    </style>
    
    <style name="TextAppearance.NetworkCards.Headline2" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="fontFamily">@font/tajawal_bold</item>
    </style>
    
    <style name="TextAppearance.NetworkCards.Subtitle1" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="fontFamily">@font/tajawal_medium</item>
    </style>
    
    <style name="TextAppearance.NetworkCards.Body1" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="fontFamily">@font/tajawal_regular</item>
    </style>
    
    <style name="TextAppearance.NetworkCards.Body2" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="fontFamily">@font/tajawal_regular</item>
    </style>
    
    <style name="TextAppearance.NetworkCards.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="fontFamily">@font/tajawal_light</item>
    </style>
    
    <!-- أنماط الأزرار المخصصة -->
    <style name="Widget.NetworkCards.Button" parent="Widget.Material3.Button">
        <item name="android:textSize">14sp</item>
        <item name="fontFamily">@font/tajawal_medium</item>
        <item name="android:letterSpacing">0</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
    </style>
    
    <style name="Widget.NetworkCards.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textSize">14sp</item>
        <item name="fontFamily">@font/tajawal_medium</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
    </style>
    
    <style name="Widget.NetworkCards.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textSize">14sp</item>
        <item name="fontFamily">@font/tajawal_medium</item>
        <item name="android:textAllCaps">false</item>
    </style>
    
    <!-- أنماط الكروت المخصصة -->
    <style name="Widget.NetworkCards.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
        <item name="contentPadding">16dp</item>
        <item name="strokeWidth">0dp</item>
    </style>
    
    <!-- أنماط حقول الإدخال المخصصة -->
    <style name="Widget.NetworkCards.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="hintTextAppearance">@style/TextAppearance.NetworkCards.Caption</item>
        <item name="android:textColorHint">@color/on_surface_variant</item>
    </style>
    
    <!-- أنماط الرقائق المخصصة -->
    <style name="Widget.NetworkCards.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">12dp</item>
        <item name="chipMinHeight">32dp</item>
        <item name="textStartPadding">12dp</item>
        <item name="textEndPadding">12dp</item>
        <item name="android:textSize">12sp</item>
        <item name="fontFamily">@font/tajawal_medium</item>
        <item name="android:textAllCaps">false</item>
    </style>
    
    <!-- أنماط التبويبات -->
    <style name="Widget.NetworkCards.TabLayout" parent="Widget.Material3.TabLayout">
        <item name="tabTextAppearance">@style/TextAppearance.NetworkCards.Body2</item>
        <item name="tabSelectedTextColor">@color/primary</item>
        <item name="tabTextColor">@color/on_surface_variant</item>
        <item name="tabIndicatorColor">@color/primary</item>
        <item name="tabIndicatorHeight">3dp</item>
        <item name="tabMode">fixed</item>
        <item name="tabGravity">fill</item>
    </style>
    
    <!-- أنماط شريط الأدوات -->
    <style name="Widget.NetworkCards.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="titleTextAppearance">@style/TextAppearance.NetworkCards.Headline2</item>
        <item name="titleTextColor">@color/on_primary</item>
        <item name="subtitleTextAppearance">@style/TextAppearance.NetworkCards.Body2</item>
        <item name="subtitleTextColor">@color/on_primary</item>
    </style>
    
    <!-- أنماط التنقل السفلي -->
    <style name="Widget.NetworkCards.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/bottom_nav_color_selector</item>
        <item name="itemTextColor">@color/bottom_nav_color_selector</item>
        <item name="itemBackground">@color/surface</item>
        <item name="elevation">8dp</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>
    
    <!-- أنماط الحوارات -->
    <style name="Widget.NetworkCards.Dialog" parent="ThemeOverlay.Material3.Dialog">
        <item name="dialogCornerRadius">16dp</item>
        <item name="android:windowBackground">@drawable/dialog_background</item>
    </style>
    
    <!-- أنماط النوافذ المنبثقة -->
    <style name="Widget.NetworkCards.BottomSheetDialog" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.NetworkCards.BottomSheet</item>
    </style>
    
    <style name="Widget.NetworkCards.BottomSheet" parent="Widget.Material3.BottomSheet.Modal">
        <item name="shapeAppearance">@style/ShapeAppearance.NetworkCards.LargeComponent</item>
        <item name="backgroundTint">@color/surface</item>
    </style>
    
    <!-- أنماط شريط التقدم -->
    <style name="Widget.NetworkCards.ProgressBar" parent="Widget.Material3.LinearProgressIndicator">
        <item name="indicatorColor">@color/primary</item>
        <item name="trackColor">@color/surface_variant</item>
        <item name="trackCornerRadius">2dp</item>
        <item name="indicatorCornerRadius">2dp</item>
        <item name="android:indeterminate">true</item>
    </style>
    
    <!-- أنماط التبديل -->
    <style name="Widget.NetworkCards.Switch" parent="Widget.Material3.CompoundButton.Switch">
        <item name="thumbTint">@color/switch_thumb_color_selector</item>
        <item name="trackTint">@color/switch_track_color_selector</item>
    </style>
    
    <!-- أنماط مربع الاختيار -->
    <style name="Widget.NetworkCards.CheckBox" parent="Widget.Material3.CompoundButton.CheckBox">
        <item name="buttonTint">@color/checkbox_color_selector</item>
    </style>
    
    <!-- أنماط زر الراديو -->
    <style name="Widget.NetworkCards.RadioButton" parent="Widget.Material3.CompoundButton.RadioButton">
        <item name="buttonTint">@color/radio_color_selector</item>
    </style>
    
    <!-- أنماط القوائم -->
    <style name="Widget.NetworkCards.ListView" parent="Widget.Material3.ListView">
        <item name="android:divider">@color/divider</item>
        <item name="android:dividerHeight">1dp</item>
    </style>
    
    <!-- أنماط الإشعارات -->
    <style name="Widget.NetworkCards.Snackbar" parent="Widget.Material3.Snackbar">
        <item name="backgroundTint">@color/surface</item>
        <item name="actionTextColor">@color/primary</item>
    </style>
    
    <!-- أنماط الأيقونات -->
    <style name="IconStyle">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
        <item name="android:tint">@color/on_surface</item>
    </style>
    
    <style name="IconStyle.Small">
        <item name="android:layout_width">18dp</item>
        <item name="android:layout_height">18dp</item>
    </style>
    
    <style name="IconStyle.Large">
        <item name="android:layout_width">32dp</item>
        <item name="android:layout_height">32dp</item>
    </style>
    
    <!-- أنماط الفواصل -->
    <style name="DividerStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">@color/divider</item>
    </style>
    
    <style name="VerticalDividerStyle">
        <item name="android:layout_width">1dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:background">@color/divider</item>
    </style>
    
</resources>