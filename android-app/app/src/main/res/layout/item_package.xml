<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeWidth="0dp"
    app:rippleColor="@color/ripple_color">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- خلفية غير نشط -->
        <View
            android:id="@+id/overlay_inactive"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@color/overlay"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- المحتوى الرئيسي -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- الرأس -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">

                <!-- أيقونة المميز -->
                <ImageView
                    android:id="@+id/icon_featured"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_star_filled"
                    android:visibility="gone"
                    app:tint="@color/accent"
                    tools:visibility="visible" />

                <!-- اسم الباقة -->
                <TextView
                    android:id="@+id/text_package_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:layout_toEndOf="@id/icon_featured"
                    android:layout_toStartOf="@id/icon_stock_warning"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/on_surface"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="باقة 50 جيجا شهرياً" />

                <!-- تحذير المخزون -->
                <ImageView
                    android:id="@+id/icon_stock_warning"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_warning"
                    android:visibility="gone"
                    app:tint="@color/error"
                    tools:visibility="visible" />

            </RelativeLayout>

            <!-- الوصف -->
            <TextView
                android:id="@+id/text_package_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="@color/on_surface_variant"
                android:textSize="13sp"
                tools:text="باقة إنترنت منزلي عالي السرعة" />

            <!-- الأسعار -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:orientation="vertical">

                <!-- سعر التجزئة -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="تجزئة:"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/text_retail_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        tools:text="100 ريال" />

                </LinearLayout>

                <!-- سعر الجملة -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="جملة:"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/text_wholesale_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        tools:text="85 ريال" />

                </LinearLayout>

                <!-- سعر الموزعين -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="موزعين:"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/text_distributor_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        tools:text="75 ريال" />

                </LinearLayout>

            </LinearLayout>

            <!-- المخزون -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="المخزون: "
                    android:textColor="@color/on_surface_variant"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/text_current_stock"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="500 كرت" />

            </LinearLayout>

            <!-- شريط تقدم المخزون -->
            <ProgressBar
                android:id="@+id/progress_stock"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginBottom="12dp"
                android:max="1000"
                android:progress="500"
                android:progressTint="@color/success"
                tools:progress="50" />

            <!-- الفئة والباركود -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:orientation="horizontal">

                <!-- الفئة -->
                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="إنترنت منزلي"
                    android:textSize="10sp"
                    app:chipBackgroundColor="@color/chip_category_bg"
                    app:chipCornerRadius="8dp"
                    app:chipMinHeight="20dp"
                    tools:text="إنترنت منزلي" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <!-- إحصائيات المبيعات -->
                <TextView
                    android:id="@+id/text_sales_stats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_sales_stats"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:textColor="@color/success"
                    android:textSize="10sp"
                    android:visibility="gone"
                    tools:text="مُبيع: 150 كرت"
                    tools:visibility="visible" />

            </LinearLayout>

            <!-- الباركود -->
            <TextView
                android:id="@+id/text_barcode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:drawablePadding="4dp"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:maxLines="1"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp"
                android:visibility="gone"
                app:drawableStartCompat="@drawable/ic_qr_code"
                app:drawableTint="@color/on_surface_variant"
                tools:text="1234567890123"
                tools:visibility="visible" />

            <!-- فاصل -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="8dp"
                android:background="@color/divider" />

            <!-- أزرار الإجراءات -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="horizontal">

                <!-- زر المخزون -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_stock"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="4dp"
                    android:contentDescription="إدارة المخزون"
                    app:icon="@drawable/ic_inventory"
                    app:iconSize="16dp"
                    app:iconTint="@color/info" />

                <!-- زر التمييز -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_toggle_featured"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="4dp"
                    android:contentDescription="تمييز الباقة"
                    app:icon="@drawable/ic_star_outline"
                    app:iconSize="16dp"
                    app:iconTint="@color/warning" />

                <!-- زر التعديل -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_edit"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:contentDescription="تعديل الباقة"
                    app:icon="@drawable/ic_edit"
                    app:iconSize="16dp"
                    app:iconTint="@color/primary" />

            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>